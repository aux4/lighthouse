{
  "scope": "aux4",
  "name": "lighthouse",
  "version": "1.0.1",
  "description": "Run Google Lighthouse audits from the command line",
  "license": "MIT",
  "tags": [
    "lighthouse",
    "performance",
    "accessibility",
    "seo",
    "audit",
    "web"
  ],
  "system": [
    [
      "test:lighthouse --version",
      "npm:lighthouse"
    ],
    [
      "test:google-chrome --version || chromium --version || chromium-browser --version",
      "brew:google-chrome",
      "apt:chromium-browser",
      "dnf:chromium",
      "apk:chromium"
    ],
    [
      "test:jq --version",
      "brew:jq",
      "linux:jq"
    ]
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "lighthouse",
          "execute": [
            "profile:lighthouse"
          ],
          "help": {
            "text": "Google Lighthouse audit commands"
          }
        }
      ]
    },
    {
      "name": "lighthouse",
      "commands": [
        {
          "name": "audit",
          "execute": [
            "set:presetFlag=!test ${preset} = desktop && echo --preset=desktop || echo ''",
            "set:categoryFlag=!test \"${category}\" != \"\" && echo \"--only-categories=${category}\" || echo ''",
            "lighthouse value(url) --output json --chrome-flags='--headless --no-sandbox' ${presetFlag} ${categoryFlag} 2>/dev/null > /tmp/.aux4-lighthouse.json || true",
            "log:Lighthouse audit for value(url)",
            "log:",
            "jq -rf ${packageDir}/lib/audit.jq /tmp/.aux4-lighthouse.json",
            "nout:rm -f /tmp/.aux4-lighthouse.json"
          ],
          "help": {
            "text": "Run a Lighthouse audit and display scores with failing audits",
            "variables": [
              {
                "name": "url",
                "text": "URL to audit",
                "arg": true
              },
              {
                "name": "preset",
                "text": "Device preset",
                "default": "mobile",
                "options": [
                  "mobile",
                  "desktop"
                ]
              },
              {
                "name": "category",
                "text": "Comma-separated categories to audit (e.g. performance,seo)",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "report",
          "execute": [
            "set:presetFlag=!test ${preset} = desktop && echo --preset=desktop || echo ''",
            "set:categoryFlag=!test \"${category}\" != \"\" && echo \"--only-categories=${category}\" || echo ''",
            "set:formatFlag=!for f in $(echo ${format} | tr ',' ' '); do printf ' --output=%s' $f; done",
            "lighthouse value(url) ${formatFlag} --output-path=value(output) --chrome-flags='--headless --no-sandbox' ${presetFlag} ${categoryFlag}"
          ],
          "help": {
            "text": "Run a Lighthouse audit and save the report",
            "variables": [
              {
                "name": "url",
                "text": "URL to audit",
                "arg": true
              },
              {
                "name": "output",
                "text": "Output file path (without extension)",
                "default": "lighthouse-report"
              },
              {
                "name": "format",
                "text": "Report format (comma-separated: html, json, csv)",
                "default": "html",
                "options": [
                  "html",
                  "json",
                  "csv",
                  "html,json"
                ]
              },
              {
                "name": "preset",
                "text": "Device preset",
                "default": "mobile",
                "options": [
                  "mobile",
                  "desktop"
                ]
              },
              {
                "name": "category",
                "text": "Comma-separated categories to audit (e.g. performance,seo)",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "scores",
          "execute": [
            "set:presetFlag=!test ${preset} = desktop && echo --preset=desktop || echo ''",
            "set:categoryFlag=!test \"${category}\" != \"\" && echo \"--only-categories=${category}\" || echo ''",
            "set:jqFilter=!test ${details} = true && echo scores-details.jq || echo scores.jq",
            "lighthouse value(url) --output json --chrome-flags='--headless --no-sandbox' ${presetFlag} ${categoryFlag} 2>/dev/null > /tmp/.aux4-lighthouse.json || true",
            "jq -f ${packageDir}/lib/${jqFilter} /tmp/.aux4-lighthouse.json",
            "nout:rm -f /tmp/.aux4-lighthouse.json"
          ],
          "help": {
            "text": "Run a quick audit and return scores as JSON",
            "variables": [
              {
                "name": "url",
                "text": "URL to audit",
                "arg": true
              },
              {
                "name": "preset",
                "text": "Device preset",
                "default": "mobile",
                "options": [
                  "mobile",
                  "desktop"
                ]
              },
              {
                "name": "category",
                "text": "Comma-separated categories to audit (e.g. performance,seo)",
                "default": ""
              },
              {
                "name": "details",
                "text": "Include failing audits in output",
                "default": "false",
                "options": [
                  "true",
                  "false"
                ]
              }
            ]
          }
        }
      ]
    }
  ]
}
